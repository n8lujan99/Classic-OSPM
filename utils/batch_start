#!/usr/bin/env bash
set -euo pipefail

# ------------------------------------------------------------
# Cluster / Julia setup
# ------------------------------------------------------------
export JULIA_DEPOT_PATH="${JULIA_DEPOT_PATH:-/scratch/09909/n8lujan99/.julia}"
export JULIA_PKG_SERVER=""

# ------------------------------------------------------------
# Resolve repo paths
# ------------------------------------------------------------
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WHICH_GAL_FILE="$REPO_ROOT/which_galaxy"

GALAXY_PROFILE_DIR="$REPO_ROOT/Data/Galaxy_Profiles"
SLURM_SCRIPT="$REPO_ROOT/Data/slurm"

# ------------------------------------------------------------
# Read selected galaxy
# ------------------------------------------------------------
if [[ ! -f "$WHICH_GAL_FILE" ]]; then
    echo "[FATAL] which_galaxy file not found at:"
    echo "        $WHICH_GAL_FILE"
    exit 1
fi

GALAXY="$(tr -d '[:space:]' < "$WHICH_GAL_FILE")"

if [[ -z "$GALAXY" ]]; then
    echo "[FATAL] which_galaxy is empty"
    exit 1
fi

# ------------------------------------------------------------
# Sanity checks
# ------------------------------------------------------------
if [[ ! -d "$GALAXY_PROFILE_DIR" ]]; then
    echo "[FATAL] Galaxy profile directory not found:"
    echo "        $GALAXY_PROFILE_DIR"
    exit 1
fi

if [[ ! -d "$GALAXY_PROFILE_DIR/$GALAXY" ]]; then
    echo "[FATAL] Galaxy profile not found:"
    echo "        $GALAXY_PROFILE_DIR/$GALAXY"
    echo
    echo "[INFO] Available galaxies:"
    ls -1 "$GALAXY_PROFILE_DIR" || true
    exit 1
fi

if [[ ! -f "$SLURM_SCRIPT" ]]; then
    echo "[FATAL] Slurm script not found at:"
    echo "        $SLURM_SCRIPT"
    exit 1
fi

mkdir -p "$REPO_ROOT/logs"

# ------------------------------------------------------------
# Submit
# ------------------------------------------------------------
echo "[INFO] Submitting OSPM-V2 job"
echo "[INFO] Repo root: $REPO_ROOT"
echo "[INFO] Galaxy:    $GALAXY"
echo "[INFO] Profiles:  $GALAXY_PROFILE_DIR"
echo "[INFO] Slurm:     $SLURM_SCRIPT"

sbatch \
    --export=ALL,OSPM_REPO_ROOT="$REPO_ROOT",OSPM_GALAXY="$GALAXY",OSPM_VERSION="V2" \
    "$SLURM_SCRIPT"
