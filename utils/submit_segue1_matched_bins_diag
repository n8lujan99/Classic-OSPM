#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_DIR="$REPO_ROOT/logs/hpc_compare/segue1_matched_bins"

mkdir -p "$LOG_DIR"

echo "[INFO] Submitting Segue1 matched-bin diagnostic"
echo "[INFO] Repo root: $REPO_ROOT"
echo "[INFO] Config:    Data.Galaxy_Profiles.Segue1Matched.Segue1Matched_OSPM_Config"
echo "[INFO] Deck:      Data/Galaxy_Profiles/Segue1/default/hpc_compare/matched_bins/daemon_deck_karl_segue1_matched_bins_vcirc.csv"

sbatch \
    --job-name=OSPM_Segue1_matched_bins \
    --output="$LOG_DIR/%x_%j.out" \
    --error="$LOG_DIR/%x_%j.err" \
    --export=ALL,OSPM_REPO_ROOT="$REPO_ROOT",OSPM_GALAXY="Segue1Matched",OSPM_COMPARE_LABEL="matched_bins",OSPM_VERSION="V2" \
    "$REPO_ROOT/Data/slurm"
